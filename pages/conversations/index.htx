<section style="max-width:800px;margin:2rem auto;padding:0 1.5rem">
  <h1 style="margin-bottom:1.5rem">Conversations</h1>

  <htx:data type="conversation" order="id DESC" limit="10" as="conversationList" />

  <div style="display:grid;gap:0.75rem">
    <htx:each items="conversationList" as="c">
      <div class="ui-card">
        <div class="ui-card-body" style="display:flex;justify-content:space-between;align-items:center">
          <div>
            <h3 class="ui-card-title" style="font-size:0.9rem">{htx:c.title}</h3>
            <p style="font-size:0.7rem;color:var(--ui-text-muted)">{htx:c.created_at}</p>
          </div>
          <span class="ui-badge" style="text-transform:uppercase;font-size:0.65rem">{htx:c.status}</span>
        </div>
      </div>
    </htx:each>
  </div>
</section>
