<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Agent Space</title>
  <link rel="stylesheet" href="/css/presto-ui.css">
  <link rel="stylesheet" href="/css/agent-space.css">
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
</head>
<body class="as-body" hx-boost="true" hx-headers='{"Authorization":"Bearer {htx:authToken}"}'>
  <nav class="as-nav">
    <a href="/" class="as-nav-brand">Agent Space</a>
    <htx:auth>
      <span class="as-nav-user">{htx:authUser.name}</span>
    </htx:auth>
    <button class="as-nav-toggle" onclick="document.getElementById('nav-links').classList.toggle('open')" aria-label="Menu">&#9776;</button>
    <div id="nav-links" class="as-nav-links">
      <a href="/" onclick="this.parentElement.classList.remove('open')">Dashboard</a>
      <a href="/chat" onclick="this.parentElement.classList.remove('open')">Chat</a>
      <a href="/agents" onclick="this.parentElement.classList.remove('open')">Agents</a>
      <a href="/delegations" onclick="this.parentElement.classList.remove('open')">Delegations</a>
      <a href="/memory" onclick="this.parentElement.classList.remove('open')">Memory</a>
      <a href="/approvals" onclick="this.parentElement.classList.remove('open')">Approvals</a>
      <a href="/attestations" onclick="this.parentElement.classList.remove('open')">Attestations</a>
      <a href="/conversations" onclick="this.parentElement.classList.remove('open')">Conversations</a>
    </div>
  </nav>
  <main id="main-content" class="as-main">
    __content__
  </main>
  <script src="/js/presto-signals.js"></script>
  <script>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var token = params.get("_t");
      if (token) {
        window.history.replaceState({}, "", window.location.pathname);
      }
    })();
  </script>
</body>
</html>
