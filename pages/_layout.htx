<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Agent Space</title>
  <link rel="stylesheet" href="/css/presto-ui.css">
  <link rel="stylesheet" href="/css/agent-space.css">
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
</head>
<body class="as-body" hx-boost="true" hx-headers='{"Authorization":"Bearer {htx:authToken}"}'>
  <nav class="as-nav">
    <a href="/" class="as-nav-brand">Agent Space</a>
    <div class="as-nav-links">
      <a href="/agents">Agents</a>
      <a href="/delegations">Delegations</a>
      <a href="/memory">Memory</a>
      <a href="/approvals">Approvals</a>
      <a href="/attestations">Attestations</a>
      <a href="/conversations">Conversations</a>
    </div>
    <htx:auth>
      <span style="font-size:0.75rem;color:var(--ui-text-muted)">{htx:authUser.name} ({htx:authUser.role})</span>
    </htx:auth>
  </nav>
  <main id="main-content" class="as-main">
    __content__
  </main>
  <script src="/js/presto-signals.js"></script>
  <script>
    // Preserve token from magic link entry — store for htmx header injection
    (function() {
      var params = new URLSearchParams(window.location.search);
      var token = params.get("_t");
      if (token) {
        // Clean the URL (remove _t param) without navigation
        var clean = window.location.pathname;
        window.history.replaceState({}, "", clean);
      }
    })();
  </script>
</body>
</html>
