<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Agent Space</title>
  <link rel="stylesheet" href="/css/presto-ui.css">
  <link rel="stylesheet" href="/css/agent-space.css">
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
</head>
<body class="as-body">
  <nav class="as-nav">
    <a href="/?_t={htx:authToken}" class="as-nav-brand">Agent Space</a>
    <div class="as-nav-links">
      <a href="/agents?_t={htx:authToken}">Agents</a>
      <a href="/delegations?_t={htx:authToken}">Delegations</a>
      <a href="/memory?_t={htx:authToken}">Memory</a>
      <a href="/approvals?_t={htx:authToken}">Approvals</a>
      <a href="/attestations?_t={htx:authToken}">Attestations</a>
      <a href="/conversations?_t={htx:authToken}">Conversations</a>
    </div>
    <htx:auth>
      <span style="font-size:0.75rem;color:var(--ui-text-muted)">{htx:authUser.name} ({htx:authUser.role})</span>
    </htx:auth>
  </nav>
  <main class="as-main">
    __content__
  </main>
  <script src="/js/presto-signals.js"></script>
</body>
</html>
