{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@presto/*": ["../presto-ts/src/*"],
      "@presto-modules/*": ["../presto-ts/modules/*"]
    }
  },
  "include": ["**/*.ts"]
}
